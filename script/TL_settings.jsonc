  "cases": [
    {
      "name": "Damage_Repaired",
      "description": "损伤修补迁移学习场景 — 修补单元数 [0,4,8,12,16,20] 等间距消融",
      "old_baseline": "health",
      "new_baseline": "damage_repaired_12",
      "damage_test": "second_damage_12",
      "TL_ablation": [
        {"freeze_strategy": ["none", "bottom", "encoder"], "trainset_size": 400}
      ],
      "TL_performance": {"freeze_strategy": "none", "trainset_size": 400},
      "difficulty_ablation": {
        "difficulty_param": "n_repair",
        "difficulty_values": [0, 4, 8, 12, 16, 20],
        "data_sizes": [50, 100, 200, 400],
        "typical_difficulty": 12
      }
    },
    {
      "name": "Sensor_Offset",
      "description": "测点偏移迁移学习场景 — 偏移测点数 [0,1,2,3,4,5] 等间距消融",
      "offset": [[2]],
